{
    auto_https {$AUTO_HTTPS:off}
    http_port {$HTTP_PORT:80}
    https_port {$HTTPS_PORT:443}
}

(gcs_proxy) {
    header_up Host storage.googleapis.com
    header_up -X-Forwarded-For
    header_up -X-Forwarded-Host
    header_up -X-Forwarded-Proto
    transport http {
        tls
        tls_server_name storage.googleapis.com
    }
}

http://{$MIRROR_DOMAIN:localhost} {
    # Serve install script with MIRROR_URL injected via template
    handle /install.sh {
        root * /srv
        templates {
            mime text/plain application/x-sh
        }
        file_server
    }

    # Internal: proxy npm registry JSON
    handle /_internal/npm-version {
        rewrite * /@anthropic-ai/claude-code/latest
        reverse_proxy https://registry.npmjs.org {
            header_up Host registry.npmjs.org
            header_up -X-Forwarded-For
            header_up -X-Forwarded-Host
            header_up -X-Forwarded-Proto
            transport http {
                tls
                tls_server_name registry.npmjs.org
            }
        }
    }

    # Return latest version as plain text
    handle /version {
        root * /srv
        rewrite * /version.txt
        templates {
            mime text/plain application/octet-stream
        }
        file_server
    }

    # Return stable version from GCS
    handle /version/stable {
        rewrite * /{$GCS_BUCKET}/claude-code-releases/stable
        reverse_proxy https://storage.googleapis.com {
            import gcs_proxy
        }
    }

    # Health check
    handle /health {
        respond "ok" 200
    }

    # Proxy binary downloads to GCS
    # handle_path strips /storage prefix before passing to inner directives
    handle_path /storage/* {
        rewrite * /{$GCS_BUCKET}/claude-code-releases{uri}
        reverse_proxy https://storage.googleapis.com {
            import gcs_proxy
        }
    }

    handle {
        respond "Not found" 404
    }

    log {
        output stdout
        format console
    }
}
