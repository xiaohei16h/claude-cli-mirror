# 镜像站域名
MIRROR_DOMAIN=claude-mirror.example.com

# GCS bucket 前缀（一般无需修改）
GCS_BUCKET=claude-code-dist-86c565f3-f756-42ad-8dfa-d59b1c096819

# 监听端口
HTTP_PORT=80
HTTPS_PORT=443

# 下载缓存：true = 缓存到本地（默认），false = 直接透传 GCS
CACHE_ENABLED=true
# 最大缓存版本数
MAX_VERSIONS=3

# HTTPS 模式：off = 仅 HTTP（默认），on = 自动 Let's Encrypt HTTPS
AUTO_HTTPS=off
